\f0\fs36 \cf0 1. \uc0\u44032 \u44172  / \u49324 \u50857 \u51088  \u51060 \u48120 \u51648  \u50577 \u51088 \u53469 \u51068 , \u54616 \u45800  \u54924 \u50896 \u44032 \u51077 \u48260 \u53948 , \u45348 \u51060 \u48260 /\u52852 \u52852 \u50724 \u47196 \u44536 \u51064  \u48260 \u53948 \
2. \uc0\u45348 \u51060 \u48260 /\u52852 \u52852 \u50724 \u47196  \u54924 \u50896 \u44032 \u51077  , \u47196 \u44536 \u51064  \u44284 \u51221  \u50508 \u50500 \u49436  \u50672 \u44208 \u54644 \u51480 \
3. \uc0\u49324 \u50857 \u51088  \u54856 \u54868 \u47732 : \u52629 \u50557 \u46108  \u50864 \u47532 \u45208 \u46972  \u51648 \u46020 \u44032  \u45208 \u50724 \u44256  \u52649 \u52397 \u45224 \u46020  \u52376 \u47100  \'93\u46020 \'94\u47560 \u45796  \u48516 \u47448 \u46104 \u50612  \u46020  \u51060 \u47492 \u51060  \u53356 \u44172  \u50024  \u51080 \u50612 . \u54644 \u45817  \'93\u46020 \'94 \u45236 \u48512 \u47484  \u53364 \u47533 \u54616 \u47732  \u51648 \u46020 \u44032  \u54869 \u45824 \u46104 \u47732 \u49436  \'93\u46020 \'94\u50504 \u51032  \'93\u49884 \'94\u45800 \u50948 \u47196  \u48372 \u51060 \u44256  \'93\u49884 \'94\u46020  \u44256 \u47476 \u47732  \u54644 \u45817  \u49884 \u51032  \u52852 \u52852 \u50724 \u47605  api\u50672 \u46041 \u51004 \u47196  \u51648 \u46020 \u44032  \u45208 \u50724 \u44256  \'93\u49884 \'94\u45236 \u48512 \u51032  \u44053 \u50500 \u51648  \u50976 \u52824 \u50896 , \u54840 \u53588 \u46308 \u51032  \u50948 \u52824 \u44032  \u46888 \u45716 \u44144 \u50556 . \u50896 \u54616 \u45716  \u44275 \u51012  \u53364 \u47533 \u54616 \u47732  \u54644 \u45817  \u50976 \u52824 \u50896 /\u54840 \u53588 \u51032  \u47196 \u44256  \u49324 \u51652 \u44284  \u50689 \u50629 \u51221 \u48372 /\u44032 \u44201 \u46321  \u49345 \u49464  \u51221 \u48372 \u47484  \u48372 \u50520 \u51004 \u47732 \u54644 . \u50812 \u51901  top\u50640 \u45716  \u49324 \u50857 \u51088 \u47749 \u51060  \u46888 \u44256  \u49324 \u50857 \u51088 \u47749 \u51012  \u45572 \u47476 \u47732  \u47560 \u51060 \u54168 \u51060 \u51648 \u47196  \u51060 \u46041 \u54644 . \u54868 \u47732  \u50724 \u47480 \u51901  \u50500 \u47000  \u51901 \u50640  \u50500 \u51060 \u53080 \u51060  \u51316 \u51116 \u54644 \u49436  \u45572 \u47476 \u47732  \u50500 \u51060 \u53080  \u50948 \u47196  \u49444 \u51221 (\u44053 \u50500 \u51648  \u54532 \u47196 \u54596 , \u52292 \u54021 )\u46308 \u51060  \u46888 \u45716 \u44144 \u50556 . \
4. \uc0\u44053 \u50500 \u51648  \u54532 \u47196 \u54596  \u54868 \u47732 : \u54788 \u51116  \u45236  \u44053 \u50500 \u51648 \u46308 \u51060  \u47532 \u49828 \u53944 \u47196  \u46888 \u47732 \u49436  \u46321 \u47197 \u54620  \u44053 \u50500 \u51648  \u50620 \u44404  \u49324 \u51652 (\u50812 \u51901 )\u44284  \u51060 \u47492 , \u45208 \u51060  (\u50724 \u47480 \u51901 )\u47564  \u51201 \u54784 \u51080 \u44256 , \u50724 \u47480 \u51901 \u50948 \u50640  \u44053 \u50500 \u51648  \u46321 \u47197 \u54616 \u44592  \u48260 \u53948 \u51004 \u47196  \u46321 \u47197  \u52285 \u51060  \u46888 \u47732 \u49436  \u44053 \u50500 \u51648  \u54532 \u47196 \u54596 \u49324 \u51652 , \u51060 \u47492 , \u45208 \u51060 , \u44053 \u50500 \u51648  \u51333 , \u53945 \u51060 \u49324 \u54637 \u46321 \u51012  \u51201 \u51012  \u49688  \u51080 \u44172  \u54644 \u51480 . \u46321 \u47197  \u48260 \u53948 \u51012  \u45572 \u47476 \u47732  \u52285 \u51060  \u44732 \u51648 \u47732 \u49436  \u44053 \u50500 \u51648  \u54532 \u47196 \u54596  \u54868 \u47732 \u50640  \u52628 \u44032 \u46104 \u44172 \u54644 \u51480 .\
5. \uc0\u52292 \u54021 \u54868 \u47732 :\u52292 \u54021 \u48169 \u51060  \u46888 \u44256  \u45572 \u47476 \u47732  \u52292 \u54021 \u52285 \u50640 \u45716  \u49345 \u45800 \u50640  \u44032 \u44172 \u51060 \u47492  \u46888 \u44172  \u54644 \u51480 .\
6. \uc0\u44032 \u44172 \u49345 \u49464 \u51221 \u48372  \u54168 \u51060 \u51648 : \u44032 \u44172  \u54532 \u47196 \u54596 \u44284  \u44032 \u44172 \u51221 \u48372 \u44032  \u46888 \u44256 , \u50696 \u50557 \u54616 \u44592 \u47484  \u45572 \u47476 \u47732  \u50696 \u50557  \u54168 \u51060 \u51648 \u47196  \u45336 \u50612 \u44032 \u44172 \
7. \uc0\u50696 \u50557  \u54168 \u51060 \u51648 : \u44053 \u50500 \u51648  \u49440 \u53469 \u52856 \u51008  \u45236 \u44032  \u46321 \u47197 \u54620  \u44053 \u50500 \u51648  \u51473 \u50640 \u49436  \u49440 \u53469 \u54624  \u49688  \u51080 \u44172  \u46888 \u44256  \u44053 \u50500 \u51648  \u51221 \u48372 \u46020  \u51088 \u46041 \u51004 \u47196  \u48520 \u47084 \u50752 , \u49324 \u50857 \u51088  \u51221 \u48372 \u46020  \u51649 \u51217 \u49440 \u53469 /\u51088 \u46041 \u51077 \u47141 (\u48520 \u47084 \u50732  \u49688  \u51080 \u44172  \u54644 ).\
